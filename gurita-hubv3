local function dapatkanTargetZombie()
    local targetTerdekat = nil
    local jarakTerdekat = BatasJarak

    for _, objek in pairs(workspace:GetChildren()) do
        if objek:IsA("Model") and objek ~= LocalPlayer.Character then
            local apakahIniPlayer = Players:GetPlayerFromCharacter(objek)
            
            if not apakahIniPlayer then
                local kepala = objek:FindFirstChild("Head")
                local humanoid = objek:FindFirstChildOfClass("Humanoid")
                
                if kepala and humanoid and humanoid.Health > 0 then
                    local jarak = (LocalPlayer.Character.HumanoidRootPart.Position - kepala.Position).Magnitude
                    
                    if jarak < jarakTerdekat then
                        jarakTerdekat = jarak
                        targetTerdekat = objek
                    end
                end
            end
        end
    end
    return targetTerdekat
end

RunService.RenderStepped:Connect(function()
    if AutoShootAktif == true and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local target = dapatkanTargetZombie()
        
        if target then
            VirtualUser:Button1Down(Vector2.new(0, 0), Camera.CFrame)
            task.wait(0.05)
        end
    end
end)
