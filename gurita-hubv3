local Window = Library.CreateLib("COACH PRIVATE", "Midnight")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local AutoShootAktif = false 
local BatasJarak = 200 

local Tab = Window:NewTab("Main")
local Section = Tab:NewSection("Combat")

Section:NewToggle("Auto Shoot Zombie", "Otomatis nembak tanpa gerakin kamera", function(state)
    AutoShootAktif = state 
end)

