local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
-- Memperkecil ukuran menu agar compact
local Window = Library.CreateLib("COACH PRIVATE", "Midnight")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local AutoShootAktif = false 
local BatasJarak = 200 

local Tab = Window:NewTab("Main")
local Section = Tab:NewSection("Combat")

Section:NewToggle("Auto Shoot Zombie", "Otomatis nembak zombi tanpa gerakin kamera", function(state)
    AutoShootAktif = state 
end)

-- Fitur tombol Z untuk buka/tutup menu
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Z then
        Library:ToggleUI()
    end
end)

local function dapatkanTargetZombie()
    local targetTerdekat = nil
    local jarakTerdekat = BatasJarak

    for _, objek in pairs(workspace:GetChildren()) do
        -- Validasi ketat: Hanya mengunci objek yang namanya ada kata Zombie/zombie
        if objek:IsA("Model") and (string.find(string.lower(objek.Name), "zombie") or string.find(string.lower(objek.Name), "zombi")) then
            local kepala = objek:FindFirstChild("Head")
            local humanoid = objek:FindFirstChildOfClass("Humanoid")
            
            if kepala and humanoid and humanoid.Health > 0 then
                local jarak = (LocalPlayer.Character.HumanoidRootPart.Position - kepala.Position).Magnitude
                
                if jarak < jarakTerdekat then
                    jarakTerdekat = jarak
                    targetTerdekat = objek
                end
            end
        end
    end
    return targetTerdekat
end

RunService.RenderStepped:Connect(function()
    if AutoShootAktif == true and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local target = dapatkanTargetZombie()
        
        if target then
            -- Kamera tidak digerakkan sama sekali, murni langsung menembak otomatis
            VirtualUser:Button1Down(Vector2.new(0, 0), Camera.CFrame)
            task.wait(0.05)
        end
    end
end)
